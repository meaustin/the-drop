# ============================================================================
# The Drop — environment. Copy to `.env.local` and fill in.
# ============================================================================

# --- Supabase (REQUIRED) ----------------------------------------------------
# Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
# Server-only secret. NEVER expose to the browser. Used by Route Handlers for
# server-authoritative writes (grading, winner selection, scheduling, redemption).
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# For `supabase link` / `supabase db push` (Project Settings → General / Database)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-db-password

# --- App --------------------------------------------------------------------
# Public base URL (used in QR codes, redemption links, push). In dev: http://localhost:3000
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
# Shared secret guarding the scheduler endpoint (/api/cron/tick). Generate any random string.
CRON_SECRET=change-me-to-a-long-random-string

# --- Anthropic (content engine; OPTIONAL — seeded library works without it) --
# console.anthropic.com → API key. Used by `npm run gen:questions` (offline batch).
ANTHROPIC_API_KEY=
# Model for generation (the spec calls for an Opus-class model for the vetted library).
ANTHROPIC_MODEL=claude-opus-4-8

# --- Web Push / VAPID (OPTIONAL — run `npm run gen:vapid` to fill these) -----
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- Twilio (OPTIONAL — SMS return-nudges; phone OTP is configured in the -----
# --- Supabase dashboard's Auth → Phone provider, not here) ------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
